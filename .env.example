# CarniLab - Environment Variables Template
# Copia este archivo como .env y completa con tus credenciales reales

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini AI
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Admin Access (cambiar en producción)
VITE_ADMIN_PASSWORD=CARNI-ADMIN-2024

# Environment
VITE_APP_ENV=development

# Sentry Error Tracking (opcional - solo para producción)
# Obtén tu DSN en: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=
